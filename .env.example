# Salin file ini menjadi .env.local lalu isi dari dashboard Supabase:
# Project Settings -> API. Tanpa kedua env ini aplikasi berjalan dalam
# demo mode (hitung tetap bisa; login, simpan, history, dan export nonaktif).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DSN project Sentry (sentry.io -> Settings -> Projects -> Client Keys).
# Opsional: tanpa ini error monitoring nonaktif, fitur lain tetap jalan.
# DSN bersifat publik (dipakai di sisi browser), bukan secret.
NEXT_PUBLIC_SENTRY_DSN=
